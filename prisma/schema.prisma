// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client_recovery"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  USER
}

type UserInformation {
  firstName String?
  lastName  String?
}

model User {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  email           String           @unique
  login           String           @unique
  name            String
  password        String
  role            Role             @default(USER)
  userInformation UserInformation?
}

model Config {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  backendApiUrl String?
  frontendUrl   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("configs")
}

model Menu {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isPublished Boolean @default(false)
  label String
  url String
  order Int?
  is_visible Boolean?
  icon String?
  icon_type String?
  is_system Boolean?
  additionalBlocks Json?
  
  @@map("menus")
}

model MenuStructure {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  fields    Json?
  
  @@map("menu_structures")
}

model Cases {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isPublished Boolean @default(false)
  nazvanie String?
  zadacha String?
  reshenie String?
  logotip String?
  tegi String?
  komanda String?
  prosmotry Int?
  additionalBlocks Json?
  
  @@map("casess")
}












model CasesStructure {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  fields    Json?
  
  @@map("cases_structures")
}

model Tags {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isPublished Boolean @default(false)
  nazvanie String?
  additionalBlocks Json?
  
  @@map("tagss")
}

model TagsStructure {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  fields    Json?
  
  @@map("tags_structures")
}

model Team {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isPublished Boolean @default(false)
  fio String?
  dolzhnost String?
  avatar String?
  additionalBlocks Json?
  
  @@map("teams")
}



model TeamStructure {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  fields    Json?
  
  @@map("team_structures")
}
